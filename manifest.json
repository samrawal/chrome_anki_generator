{
  "manifest_version": 3,
  "name": "MKSAP Anki Cloze",
  "version": "0.1.0",
  "description": "Generate one Anki cloze card from the current MKSAP answer page using local Codex app-server.",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    },
    "default_title": "Create Anki cloze"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://mksap.acponline.org/app/*"],
      "js": ["src/contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icon16.png",
        "assets/icon32.png",
        "assets/icon48.png",
        "assets/icon128.png"
      ],
      "matches": ["https://mksap.acponline.org/*"]
    }
  ],
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://mksap.acponline.org/app/*",
    "http://127.0.0.1:4555/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://127.0.0.1:4555"
  }
}
